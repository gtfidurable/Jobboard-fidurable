<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Board Fidurable - Offres ESG & Finance</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #1a472a;
            --secondary: #2d6a4f;
            --accent: #40916c;
            --light-accent: #52b788;
            --bg: #f1faee;
            --text: #1b263b;
            --text-light: #457b9d;
            --border: #a8dadc;
            --success: #2a9d8f;
            --warning: #e76f51;
            --danger: #d62828;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            background: linear-gradient(135deg, var(--bg) 0%, #e8f5e9 100%);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Header */
        header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            padding: 2rem 1rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 2rem;
        }

        .header-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .header-title h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
            font-weight: 700;
        }

        .header-title p {
            font-size: 0.95rem;
            opacity: 0.9;
        }

        .header-stats {
            display: flex;
            gap: 2rem;
            font-size: 0.9rem;
        }

        .stat {
            text-align: center;
        }

        .stat-number {
            font-size: 1.8rem;
            font-weight: bold;
            display: block;
        }

        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        /* Filters Section */
        .filters-section {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 1px solid var(--border);
        }

        .filters-title {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .filters-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
        }

        .filter-group label {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text);
            font-size: 0.9rem;
        }

        .filter-group select,
        .filter-group input {
            padding: 0.75rem;
            border: 2px solid var(--border);
            border-radius: 8px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: white;
            color: var(--text);
        }

        .filter-group select:hover,
        .filter-group input:hover {
            border-color: var(--accent);
        }

        .filter-group select:focus,
        .filter-group input:focus {
            outline: none;
            border-color: var(--secondary);
            box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.1);
        }

        .filter-buttons {
            display: flex;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        button {
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent) 0%, var(--light-accent) 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(64, 145, 108, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(64, 145, 108, 0.4);
        }

        .btn-secondary {
            background: white;
            color: var(--primary);
            border: 2px solid var(--primary);
        }

        .btn-secondary:hover {
            background: var(--bg);
        }

        /* Results Section */
        .results-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .results-count {
            font-size: 1rem;
            color: var(--text-light);
            font-weight: 500;
        }

        .sort-group {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .sort-group select {
            padding: 0.5rem 1rem;
            border: 2px solid var(--border);
            border-radius: 8px;
            background: white;
            color: var(--text);
        }

        /* Job Cards Grid */
        .jobs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .job-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            border: 2px solid transparent;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .job-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--accent) 0%, var(--light-accent) 100%);
        }

        .job-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
            border-color: var(--accent);
        }

        .job-header {
            margin-bottom: 1rem;
        }

        .job-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
            line-height: 1.4;
        }

        .job-company {
            font-size: 0.95rem;
            color: var(--text-light);
            font-weight: 500;
        }

        .job-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .badge {
            display: inline-block;
            padding: 0.4rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            white-space: nowrap;
        }

        .badge-contract {
            background: rgba(64, 145, 108, 0.15);
            color: var(--secondary);
        }

        .badge-sector {
            background: rgba(42, 157, 143, 0.15);
            color: var(--success);
        }

        .badge-location {
            background: rgba(231, 111, 81, 0.15);
            color: var(--warning);
        }

        .badge-level {
            background: rgba(26, 71, 42, 0.15);
            color: var(--primary);
        }

        .badge-esg {
            background: rgba(82, 183, 136, 0.15);
            color: var(--light-accent);
            border: 1px solid var(--light-accent);
        }

        .job-description {
            font-size: 0.9rem;
            color: var(--text);
            margin-bottom: 1rem;
            flex-grow: 1;
            line-height: 1.5;
        }

        .job-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
        }

        .detail-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .detail-label {
            font-weight: 600;
            color: var(--text-light);
        }

        .detail-value {
            color: var(--text);
        }

        .job-footer {
            display: flex;
            gap: 0.75rem;
        }

        .btn-apply {
            flex: 1;
            background: linear-gradient(135deg, var(--accent) 0%, var(--light-accent) 100%);
            color: white;
            padding: 0.75rem;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-apply:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(64, 145, 108, 0.3);
        }

        .btn-share {
            background: white;
            color: var(--primary);
            border: 2px solid var(--primary);
            padding: 0.6rem 0.8rem;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-share:hover {
            background: var(--bg);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-light);
        }

        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
            color: var(--text);
        }

        /* Loading State */
        .loading {
            text-align: center;
            padding: 3rem 1rem;
        }

        .spinner {
            border: 4px solid var(--border);
            border-top: 4px solid var(--accent);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 1rem;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Footer */
        footer {
            background: var(--primary);
            color: white;
            padding: 2rem 1rem;
            text-align: center;
            margin-top: 3rem;
            font-size: 0.9rem;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: var(--light-accent);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-links a:hover {
            color: white;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                text-align: center;
            }

            .header-stats {
                justify-content: center;
            }

            .filters-grid {
                grid-template-columns: 1fr;
            }

            .jobs-grid {
                grid-template-columns: 1fr;
            }

            .header-title h1 {
                font-size: 1.5rem;
            }

            .job-details {
                grid-template-columns: 1fr;
            }
        }

        /* Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .job-card {
            animation: fadeIn 0.3s ease-out forwards;
        }

        .job-card:nth-child(1) { animation-delay: 0s; }
        .job-card:nth-child(2) { animation-delay: 0.05s; }
        .job-card:nth-child(3) { animation-delay: 0.1s; }
        .job-card:nth-child(4) { animation-delay: 0.15s; }
        .job-card:nth-child(5) { animation-delay: 0.2s; }
        .job-card:nth-child(6) { animation-delay: 0.25s; }

        .error-message {
            background: rgba(214, 40, 40, 0.1);
            border: 2px solid var(--danger);
            color: var(--danger);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            text-align: center;
        }

        .info-message {
            background: rgba(42, 157, 143, 0.1);
            border: 2px solid var(--success);
            color: var(--success);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="header-container">
            <div class="header-content">
                <div class="header-title">
                    <h1>🌱 Job Board Fidurable</h1>
                    <p>Découvrez les meilleures offres en Finance, ESG et Économie Circulaire</p>
                </div>
                <div class="header-stats">
                    <div class="stat">
                        <span class="stat-number" id="total-jobs">0</span>
                        <span>Offres actives</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number" id="total-companies">0</span>
                        <span>Entreprises</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <div class="container">
        <!-- Info Message -->
        <div id="info-message" style="display: none;"></div>

        <!-- Error Message -->
        <div id="error-message" style="display: none;"></div>

        <!-- Filters -->
        <div class="filters-section">
            <div class="filters-title">🔍 Filtrer les offres</div>
            <div class="filters-grid">
                <div class="filter-group">
                    <label for="filter-contract">Type de contrat</label>
                    <select id="filter-contract">
                        <option value="">Tous les types</option>
                        <option value="CDI">CDI</option>
                        <option value="CDD">CDD</option>
                        <option value="Stage">Stage</option>
                        <option value="Alternance">Alternance</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-sector">Secteur d'activité</label>
                    <select id="filter-sector">
                        <option value="">Tous les secteurs</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-location">Localisation</label>
                    <select id="filter-location">
                        <option value="">Toutes les villes</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-level">Niveau d'étude</label>
                    <select id="filter-level">
                        <option value="">Tous les niveaux</option>
                    </select>
                </div>
            </div>

            <div class="filter-buttons">
                <button class="btn-primary" onclick="applyFilters()">🔍 Appliquer les filtres</button>
                <button class="btn-secondary" onclick="resetFilters()">↻ Réinitialiser</button>
            </div>
        </div>

        <!-- Results -->
        <div class="results-header">
            <div class="results-count">
                Affichage de <strong id="displayed-count">0</strong> sur <strong id="total-count">0</strong> offres
            </div>
            <div class="sort-group">
                <label for="sort">Trier par :</label>
                <select id="sort" onchange="applyFilters()">
                    <option value="recent">Plus récent</option>
                    <option value="company">Entreprise (A-Z)</option>
                    <option value="title">Titre du poste (A-Z)</option>
                </select>
            </div>
        </div>

        <!-- Jobs Grid -->
        <div class="jobs-grid" id="jobs-grid"></div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-links">
                <a href="https://fidurable.fr" target="_blank">Fidurable</a>
                <a href="mailto:contact@fidurable.fr">Nous contacter</a>
                <a href="#" onclick="showNotification('Fonctionnalité à venir')">À propos</a>
            </div>
            <p>&copy; 2026 Fidurable - Job Board ESG & Finance. Connecté à Notion ✅</p>
        </div>
    </footer>

    <script>
        // ========================================
        // CONFIGURATION NOTION API
        // ========================================
        
        const NOTION_API_KEY = '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';
        const NOTION_DATABASE_ID = '2debea8145ec8083a9e9c426797e1763';
        
        // Utiliser un proxy CORS gratuit pour contourner les restrictions
        const CORS_PROXY = 'https://cors-anywhere.herokuapp.com/';
        const NOTION_API_URL = `${CORS_PROXY}https://api.notion.com/v1/databases/${NOTION_DATABASE_ID}/query`;

        // Headers pour les requêtes Notion
        const notionHeaders = {
            'Authorization': `Bearer ${NOTION_API_KEY}`,
            'Notion-Version': '2022-06-28',
            'Content-Type': 'application/json'
        };

        // Variables globales
        let allJobsData = [];
        let filteredJobsData = [];

        // ========================================
        // RÉCUPÉRATION DES DONNÉES NOTION
        // ========================================

        async function fetchJobsFromNotion() {
            try {
                // Afficher le loader
                showLoading();

                const response = await fetch(NOTION_API_URL, {
                    method: 'POST',
                    headers: notionHeaders,
                    body: JSON.stringify({
                        filter: {
                            property: 'Statut',
                            select: {
                                equals: 'Actif'
                            }
                        },
                        sorts: [
                            {
                                property: 'Date de Publication',
                                direction: 'descending'
                            }
                        ],
                        page_size: 100
                    })
                });

                if (!response.ok) {
                    throw new Error(`Erreur API: ${response.status} ${response.statusText}`);
                }

                const data = await response.json();

                // Parser les résultats
                allJobsData = data.results.map(parseJobFromNotion);

                // Remplir les filtres avec les valeurs disponibles
                populateFilters();

                // Afficher les offres
                displayJobs(allJobsData);
                updateStats();

                // Masquer les erreurs
                document.getElementById('error-message').style.display = 'none';
                document.getElementById('info-message').style.display = 'none';

            } catch (error) {
                console.error('Erreur lors de la récupération des données:', error);
                
                // Essayer une approche alternative
                tryAlternativeConnection();
            }
        }

        // Essayer une connexion alternative sans proxy
        async function tryAlternativeConnection() {
            try {
                showInfo('Tentative de connexion directe à Notion...');
                
                const response = await fetch(
                    `https://api.notion.com/v1/databases/${NOTION_DATABASE_ID}/query`,
                    {
                        method: 'POST',
                        headers: notionHeaders,
                        body: JSON.stringify({
                            filter: {
                                property: 'Statut',
                                select: { equals: 'Actif' }
                            }
                        })
                    }
                );

                if (!response.ok) {
                    throw new Error(`Erreur: ${response.status}`);
                }

                const data = await response.json();
                allJobsData = data.results.map(parseJobFromNotion);
                populateFilters();
                displayJobs(allJobsData);
                updateStats();
                document.getElementById('info-message').style.display = 'none';

            } catch (error) {
                console.error('Erreur connexion directe:', error);
                showError('Impossible de se connecter à Notion. Vérifiez votre clé API et Database ID.');
                showEmptyState('Erreur de connexion', 'Veuillez vérifier votre configuration Notion');
            }
        }

        // Parser une offre depuis Notion
        function parseJobFromNotion(page) {
            const props = page.properties;

            return {
                id: page.id,
                title: props['Titre du Poste']?.title?.[0]?.plain_text || 'Sans titre',
                company: props['Entreprise']?.rich_text?.[0]?.plain_text || 'Entreprise inconnue',
                sector: props['Secteur d\'Activité']?.select?.name || 'Non spécifié',
                contract: props['Type de Contrat']?.select?.name || 'Non spécifié',
                location: props['Localisation']?.select?.name || 'Non spécifié',
                level: props['Niveau d\'Étude Requis']?.select?.name || 'Non spécifié',
                experience: props['Niveau d\'Expérience']?.select?.name || 'Non spécifié',
                description: props['Description Résumée']?.rich_text?.[0]?.plain_text || 'Pas de description',
                source: props['Source']?.select?.name || 'Autre',
                link: props['Lien de l\'Offre']?.url || '#',
                esgFocus: props['Domaine ESG Focus']?.multi_select?.map(tag => tag.name) || [],
                remote: props['Télétravail Possible']?.checkbox || false,
                salary: props['Salaire Estimé']?.rich_text?.[0]?.plain_text || '',
                rating: props['Pertinence pour Fidurable']?.select?.name || '',
                status: props['Statut']?.select?.name || 'Actif'
            };
        }

        // ========================================
        // GESTION DE L'AFFICHAGE
        // ========================================

        function displayJobs(jobs) {
            const grid = document.getElementById('jobs-grid');
            grid.innerHTML = '';

            if (jobs.length === 0) {
                showEmptyState('Aucune offre trouvée', 'Essayez d\'ajuster vos filtres');
                document.getElementById('displayed-count').textContent = '0';
                return;
            }

            jobs.forEach((job, index) => {
                const card = createJobCard(job);
                grid.appendChild(card);
            });

            document.getElementById('displayed-count').textContent = jobs.length;
            document.getElementById('total-count').textContent = allJobsData.length;
        }

        function createJobCard(job) {
            const card = document.createElement('div');
            card.className = 'job-card';

            const esgBadge = job.esgFocus.length > 0 
                ? `<span class="badge badge-esg">🌱 ESG Focus</span>` 
                : '';

            card.innerHTML = `
                <div class="job-header">
                    <div class="job-title">${escapeHtml(job.title)}</div>
                    <div class="job-company">${escapeHtml(job.company)}</div>
                </div>

                <div class="job-meta">
                    <span class="badge badge-contract">${escapeHtml(job.contract)}</span>
                    <span class="badge badge-sector">${escapeHtml(job.sector)}</span>
                    <span class="badge badge-location">📍 ${escapeHtml(job.location)}</span>
                    <span class="badge badge-level">${escapeHtml(job.level)}</span>
                    ${esgBadge}
                </div>

                <div class="job-description">${escapeHtml(job.description)}</div>

                <div class="job-details">
                    <div class="detail-item">
                        <span class="detail-label">Type :</span>
                        <span class="detail-value">${escapeHtml(job.contract)}</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Localisation :</span>
                        <span class="detail-value">${escapeHtml(job.location)}</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Source :</span>
                        <span class="detail-value">${escapeHtml(job.source)}</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Niveau :</span>
                        <span class="detail-value">${escapeHtml(job.level)}</span>
                    </div>
                </div>

                <div class="job-footer">
                    <a href="${job.link}" target="_blank" class="btn-apply">
                        Voir l'offre →
                    </a>
                    <button class="btn-share" onclick="shareJob('${escapeHtml(job.title)}', '${escapeHtml(job.company)}')">
                        📤
                    </button>
                </div>
            `;

            return card;
        }

        function showLoading() {
            document.getElementById('jobs-grid').innerHTML = `
                <div style="grid-column: 1/-1;">
                    <div class="loading">
                        <div class="spinner"></div>
                        <p>Chargement des offres...</p>
                    </div>
                </div>
            `;
        }

        function showEmptyState(title, message) {
            document.getElementById('jobs-grid').innerHTML = `
                <div style="grid-column: 1/-1;">
                    <div class="empty-state">
                        <div class="empty-state-icon">🔍</div>
                        <h3>${title}</h3>
                        <p>${message}</p>
                    </div>
                </div>
            `;
        }

        function showError(message) {
            const errorDiv = document.getElementById('error-message');
            errorDiv.className = 'error-message';
            errorDiv.textContent = '⚠️ ' + message;
            errorDiv.style.display = 'block';
        }

        function showInfo(message) {
            const infoDiv = document.getElementById('info-message');
            infoDiv.className = 'info-message';
            infoDiv.textContent = 'ℹ️ ' + message;
            infoDiv.style.display = 'block';
        }

        // ========================================
        // FILTRES
        // ========================================

        function populateFilters() {
            // Récupérer les valeurs uniques
            const sectors = [...new Set(allJobsData.map(job => job.sector))].sort();
            const locations = [...new Set(allJobsData.map(job => job.location))].sort();
            const levels = [...new Set(allJobsData.map(job => job.level))].sort();

            // Remplir les sélects
            const sectorSelect = document.getElementById('filter-sector');
            sectors.forEach(sector => {
                const option = document.createElement('option');
                option.value = sector;
                option.textContent = sector;
                sectorSelect.appendChild(option);
            });

            const locationSelect = document.getElementById('filter-location');
            locations.forEach(location => {
                const option = document.createElement('option');
                option.value = location;
                option.textContent = location;
                locationSelect.appendChild(option);
            });

            const levelSelect = document.getElementById('filter-level');
            levels.forEach(level => {
                const option = document.createElement('option');
                option.value = level;
                option.textContent = level;
                levelSelect.appendChild(option);
            });
        }

        function applyFilters() {
            const contract = document.getElementById('filter-contract').value;
            const sector = document.getElementById('filter-sector').value;
            const location = document.getElementById('filter-location').value;
            const level = document.getElementById('filter-level').value;
            const sort = document.getElementById('sort').value;

            // Filtrer
            let filtered = allJobsData.filter(job => {
                return (!contract || job.contract === contract) &&
                       (!sector || job.sector === sector) &&
                       (!location || job.location === location) &&
                       (!level || job.level === level);
            });

            // Trier
            if (sort === 'company') {
                filtered.sort((a, b) => a.company.localeCompare(b.company));
            } else if (sort === 'title') {
                filtered.sort((a, b) => a.title.localeCompare(b.title));
            } else {
                filtered.sort((a, b) => b.id.localeCompare(a.id));
            }

            displayJobs(filtered);
        }

        function resetFilters() {
            document.getElementById('filter-contract').value = '';
            document.getElementById('filter-sector').value = '';
            document.getElementById('filter-location').value = '';
            document.getElementById('filter-level').value = '';
            document.getElementById('sort').value = 'recent';
            displayJobs(allJobsData);
        }

        // ========================================
        // STATISTIQUES
        // ========================================

        function updateStats() {
            const companies = [...new Set(allJobsData.map(job => job.company))];
            document.getElementById('total-jobs').textContent = allJobsData.length;
            document.getElementById('total-companies').textContent = companies.length;
        }

        // ========================================
        // UTILITAIRES
        // ========================================

        function shareJob(title, company) {
            const text = `Découvrez cette offre : ${title} chez ${company} sur le Job Board Fidurable 🌱`;
            if (navigator.share) {
                navigator.share({
                    title: 'Job Board Fidurable',
                    text: text,
                    url: window.location.href
                });
            } else {
                alert('Lien : ' + window.location.href);
            }
        }

        function showNotification(message) {
            alert(message);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ========================================
        // INITIALISATION
        // ========================================

        document.addEventListener('DOMContentLoaded', function() {
            fetchJobsFromNotion();
            
            // Rafraîchir les données toutes les 60 secondes
            setInterval(fetchJobsFromNotion, 60000);
        });
    </script>
</body>
</html>
